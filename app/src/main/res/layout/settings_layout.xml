<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settings_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/application_background"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        android:fadeScrollbars="false"
        app:layout_constraintBottom_toTopOf="@id/bottomNavBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:layout_marginTop="30dp"
                android:importantForAccessibility="no"
                android:src="@drawable/icon_settings_circle_100" />

            <TextView
                android:id="@+id/settings_fptn_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:text="@string/app_version"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/round_settings_back_white10_20"
                android:orientation="vertical"
                android:padding="10dp">

                <TextView
                    android:id="@+id/settings_about"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="20dp"
                    android:layout_marginBottom="10dp"
                    android:justificationMode="inter_word"
                    android:text="@string/info_message_html"
                    android:textAlignment="viewStart"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Your SNI -->
            <LinearLayout
                android:id="@+id/sni_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/round_settings_back_white10_20"
                android:orientation="vertical"
                android:padding="10dp"
                android:paddingBottom="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/sni_image_view"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:importantForAccessibility="no"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:src="@drawable/ic_baseline_your_servers_24" />

                    <TextView
                        android:id="@+id/SNI_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/sni_image_view"
                        android:text="@string/your_current_sni"
                        android:textColor="@color/white"
                        android:textStyle="normal" />

                    <TextView
                        android:id="@+id/SNI_text_field"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="12dp"
                        android:layout_toStartOf="@+id/imageView"
                        android:layout_toEndOf="@id/SNI_label"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:text="@string/default_sni"
                        android:textColor="@color/white"
                        android:textStyle="normal" />

                    <ImageView
                        android:id="@+id/imageView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_outline_arrow_forward_ios_16"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/sni_text_description"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:paddingTop="8dp"
                    android:paddingRight="10dp"
                    android:paddingBottom="10dp"
                    android:text="@string/sni_text_description"
                    android:textColor="@color/gray"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Required permissions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/round_settings_back_white10_20"
                android:orientation="vertical"
                android:paddingLeft="10dp"
                android:paddingTop="10dp"
                android:paddingRight="10dp"
                android:paddingBottom="10dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/required_permissions_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="16dp"
                        android:layout_centerVertical="true"
                        android:layout_gravity="center"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:importantForAccessibility="no"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:src="@drawable/user_permissions_24" />

                    <TextView
                        android:id="@+id/required_permissions_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/required_permissions_icon"
                        android:text="@string/required_permissions"
                        android:textColor="@color/white"
                        android:textStyle="normal" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="4dp">

                    <!-- Notification permission -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="0dp">

                        <ImageView
                            android:id="@+id/permission_icon_show_notification"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:paddingStart="0dp"
                            android:paddingEnd="8dp"
                            android:src="@drawable/bell_ring_24" />

                        <TextView
                            android:id="@+id/permission_label_show_notification"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/permission_icon_show_notification"
                            android:text="@string/show_notification_label"
                            android:textColor="@color/white"
                            android:textStyle="normal" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/permission_show_notification_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:enabled="true"
                            android:paddingEnd="2dp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Battery optimisation disable permission -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="0dp">

                        <ImageView
                            android:id="@+id/permission_icon_battery_optimization"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:paddingStart="0dp"
                            android:paddingEnd="8dp"
                            android:src="@drawable/eco_battery_24" />

                        <TextView
                            android:id="@+id/permission_label_battery_optimization"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/permission_icon_battery_optimization"
                            android:text="@string/battery_optimization_request_dialog_title"
                            android:textColor="@color/white"
                            android:textStyle="normal" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/permission_battery_optimization_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:enabled="true"
                            android:paddingEnd="2dp"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <!-- Background data transfer without restrictions permission -->
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingVertical="0dp">

                        <ImageView
                            android:id="@+id/permission_icon_background_data_transfer"
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:layout_gravity="center"
                            android:importantForAccessibility="no"
                            android:paddingStart="0dp"
                            android:paddingEnd="8dp"
                            android:src="@drawable/cloud_back_up_24" />


                        <TextView
                            android:id="@+id/permission_label_background_data_transfer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_toEndOf="@id/permission_icon_background_data_transfer"
                            android:text="@string/background_data_request_dialog_title"
                            android:textColor="@color/white"
                            android:textStyle="normal" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/permission_background_data_transfer_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentTop="true"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:enabled="true"
                            android:paddingEnd="2dp"
                            android:textStyle="bold"
                            tools:ignore="UseSwitchCompatOrMaterialXml" />
                    </RelativeLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- UPDATE TOKEN -->
            <LinearLayout
                android:id="@+id/update_token_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/round_settings_back_white10_20"
                android:orientation="vertical"
                android:padding="10dp"
                android:paddingBottom="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/setting_update_token_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:importantForAccessibility="no"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:src="@drawable/ic_baseline_update_24" />

                    <TextView
                        android:id="@+id/updateTokenLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@+id/imageView2"
                        android:layout_toEndOf="@id/setting_update_token_icon"
                        android:text="@string/update_token_button"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/imageView2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_outline_arrow_forward_ios_16"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp">

                    <TextView
                        android:id="@+id/settings_token_info_html"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingLeft="10dp"
                        android:paddingTop="10dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="10dp"
                        android:text="@string/settings_token_info_html"
                        android:textColor="@color/gray"
                        android:textSize="12sp" />
                </RelativeLayout>
            </LinearLayout>

            <!-- Your VPN servers -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/round_settings_back_white10_20"
                android:orientation="vertical"
                android:padding="10dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/settings_available_servers_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:importantForAccessibility="no"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:src="@drawable/ic_baseline_your_servers_24" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/settings_available_servers_icon"
                        android:text="@string/your_servers"
                        android:textColor="@color/white"
                        android:textStyle="normal" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp"
                    android:orientation="vertical"
                    android:paddingLeft="10dp">

                    <ListView
                        android:id="@+id/settings_servers_list"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:divider="@android:color/transparent"
                        android:dividerHeight="0dp"
                        tools:listitem="@layout/settings_server_list_item" />
                </LinearLayout>
            </LinearLayout>

            <!-- Experimental features settings -->
            <LinearLayout
                android:id="@+id/experimental_features_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/round_settings_back_white10_20"
                android:orientation="vertical"
                android:padding="10dp"
                android:paddingBottom="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/setting_experimental_features_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:importantForAccessibility="no"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:src="@drawable/ic_experimental_features_24" />

                    <TextView
                        android:id="@+id/experimental_features_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toStartOf="@id/experimental_features_button"
                        android:layout_toEndOf="@id/setting_experimental_features_icon"
                        android:text="@string/experimental_features_label"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/experimental_features_button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:importantForAccessibility="no"
                        android:src="@drawable/ic_outline_arrow_forward_ios_16"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="0dp">

                    <TextView
                        android:id="@+id/experimental_features_info_html"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingLeft="10dp"
                        android:paddingTop="10dp"
                        android:paddingRight="10dp"
                        android:paddingBottom="10dp"
                        android:text="@string/experimental_features_info"
                        android:textColor="@color/gray"
                        android:textSize="12sp" />
                </RelativeLayout>
            </LinearLayout>


            <!-- LOGOUT -->
            <RelativeLayout
                android:id="@+id/logout_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/round_settings_back_white10_20"
                android:orientation="vertical"
                android:padding="10dp">

                <ImageView
                    android:id="@+id/setting_logout_icon"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_gravity="center"
                    android:importantForAccessibility="no"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:src="@drawable/ic_baseline_logout_24" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@id/arrow_logout_image_view"
                    android:layout_toEndOf="@id/setting_logout_icon"
                    android:text="@string/logout_button"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/arrow_logout_image_view"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_outline_arrow_forward_ios_16"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </RelativeLayout>


            <!-- Sponsors -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/round_settings_back_white10_20"
                android:orientation="vertical"
                android:padding="10dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/sponsors_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:importantForAccessibility="no"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:src="@drawable/ic_sponsors_update_24" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_toEndOf="@id/sponsors_icon"
                        android:text="@string/sponsors_text"
                        android:textColor="@color/white"
                        android:textStyle="normal" />
                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:orientation="vertical"
                    android:paddingLeft="12dp">

                    <TextView
                        android:id="@+id/sponsors_list"
                        android:layout_width="fill_parent"
                        android:layout_height="wrap_content"
                        android:lineSpacingExtra="8dp"
                        android:maxLines="10"
                        android:scrollbars="vertical"
                        android:text="@string/sponsors_usernames"
                        android:textColor="@color/white"
                        android:textStyle="normal" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_nav_bar_menu" />

</androidx.constraintlayout.widget.ConstraintLayout>